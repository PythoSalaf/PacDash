{
  "rewrites": [
    { "source": "/(.*)", "destination": "/index.html" },
    {
      "source": "/elfa-api/:path*",
      "destination": "https://api.elfa.ai/v2/:path*"
    }
  ],
    "headers": [
    {
      "source": "/elfa-api/(.*)",
      "headers": [
        {
          "key": "Access-Control-Allow-Origin",
          "value": "*"
        }
      ]
    }
  ]
}